{
  "version": 1,
  "node": {
    "id": "phenix-tools",
    "description": "Verify the phenix-tools workspace",
    "tags": ["tooling", "foundation"],
    "when": {
      "changed": {
        "paths": ["crates/**", ".tend.json"]
      }
    },
    "tasks": [
      {
        "id": "tend-crate-files",
        "phase": "verify",
        "kind": "filesExist",
        "paths": [
          "crates/tend/Cargo.toml",
          "crates/tend/src/lib.rs",
          "crates/tend-cli/Cargo.toml",
          "crates/tend-cli/src/main.rs"
        ]
      },
      {
        "id": "cargo-check",
        "phase": "verify",
        "kind": "command",
        "command": ["cargo", "check", "--quiet", "--workspace", "--all-targets"],
        "description": "Check that the workspace compiles cleanly"
      },
      {
        "id": "cargo-clippy",
        "phase": "verify",
        "kind": "command",
        "command": ["cargo", "clippy", "--quiet", "--workspace", "--all-targets", "--", "-D", "warnings"],
        "description": "Run clippy with deny-warnings on workspace"
      }
    ]
  }
}
