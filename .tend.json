{
  "version": 1,
  "node": {
    "id": "phenix-tools",
    "description": "Verify the phenix-tools workspace",
    "tags": ["tooling", "foundation"],
    "when": {
      "changed": {
        "paths": ["Cargo.toml", "Cargo.lock", "crates/**/*.rs", "modules/**/*.nix", ".tend.json"]
      }
    },
    "tasks": [
      {
        "id": "rustfmt-check",
        "description": "Check Rust formatting",
        "phase": "verify",
        "kind": "command",
        "command": ["cargo", "fmt", "--all", "--check"],
        "profiles": ["git-hook", "pre-push", "manual", "nix-check"],
        "tags": ["format", "rust"],
        "sandbox_safe": true,
        "mutates": false,
        "always": true,
        "when": {
          "changed": {
            "paths": ["Cargo.toml", "Cargo.lock", "crates/**/*.rs", "modules/**/*.nix"]
          }
        }
      },
      {
        "id": "cargo-check",
        "description": "Check that the workspace compiles cleanly",
        "phase": "verify",
        "kind": "command",
        "command": ["cargo", "check", "--quiet", "--workspace", "--all-targets"],
        "profiles": ["pre-push", "manual", "nix-check"],
        "tags": ["rust", "compile"],
        "sandbox_safe": true,
        "mutates": false,
        "always": true,
        "when": {
          "changed": {
            "paths": ["Cargo.toml", "Cargo.lock", "crates/**/*.rs"]
          }
        }
      },
      {
        "id": "cargo-clippy",
        "description": "Run clippy with deny-warnings on workspace",
        "phase": "verify",
        "kind": "command",
        "command": ["cargo", "clippy", "--quiet", "--workspace", "--all-targets", "--", "-D", "warnings"],
        "profiles": ["pre-push", "manual", "nix-check"],
        "tags": ["rust", "lint"],
        "sandbox_safe": true,
        "mutates": false,
        "always": true,
        "when": {
          "changed": {
            "paths": ["Cargo.toml", "Cargo.lock", "crates/**/*.rs"]
          }
        }
      },
      {
        "id": "cargo-test",
        "description": "Run Rust tests",
        "phase": "verify",
        "kind": "command",
        "command": ["cargo", "test", "--workspace"],
        "profiles": ["manual", "nix-check"],
        "tags": ["rust", "test"],
        "sandbox_safe": true,
        "mutates": false,
        "always": true,
        "when": {
          "changed": {
            "paths": ["Cargo.toml", "Cargo.lock", "crates/**/*.rs"]
          }
        }
      },
      {
        "id": "nixfmt-check",
        "description": "Check Nix files are formatted correctly",
        "phase": "verify",
        "kind": "command",
        "command": ["bash", "-c", "find modules -name '*.nix' -print0 | xargs -0 -r nixfmt --check && find . -maxdepth 1 -name '*.nix' -print0 | xargs -0 -r nixfmt --check"],
        "profiles": ["git-hook", "pre-push", "manual", "nix-check"],
        "tags": ["nix", "format"],
        "sandbox_safe": true,
        "mutates": false,
        "always": true,
        "when": {
          "changed": {
            "paths": ["modules/**/*.nix"]
          }
        }
      },
      {
        "id": "statix-check",
        "description": "Lint Nix files with statix",
        "phase": "verify",
        "kind": "command",
        "command": ["statix", "check"],
        "profiles": ["git-hook", "pre-push", "manual", "nix-check"],
        "tags": ["nix", "lint"],
        "sandbox_safe": true,
        "mutates": false,
        "always": true,
        "when": {
          "changed": {
            "paths": ["modules/**/*.nix"]
          }
        }
      },
      {
        "id": "deadnix-check",
        "description": "Find and report dead Nix code",
        "phase": "verify",
        "kind": "command",
        "command": ["deadnix", "--fail", "--no-lambda-arg", "--no-lambda-pattern-names"],
        "profiles": ["git-hook", "pre-push", "manual", "nix-check"],
        "tags": ["nix", "cleanup"],
        "sandbox_safe": true,
        "mutates": false,
        "always": true,
        "when": {
          "changed": {
            "paths": ["modules/**/*.nix"]
          }
        }
      },
      {
        "id": "rustfmt-fix",
        "description": "Fix Rust formatting",
        "phase": "fix",
        "kind": "command",
        "command": ["cargo", "fmt", "--all"],
        "profiles": ["fix"],
        "tags": ["format", "rust", "fix"],
        "sandbox_safe": false,
        "mutates": true,
        "when": {
          "changed": {
            "paths": ["Cargo.toml", "Cargo.lock", "crates/**/*.rs"]
          }
        }
      },
      {
        "id": "nixfmt-fix",
        "description": "Auto-format Nix files",
        "phase": "fix",
        "kind": "command",
        "command": ["bash", "-c", "find modules -name '*.nix' -print0 | xargs -0 -r nixfmt && find . -maxdepth 1 -name '*.nix' -print0 | xargs -0 -r nixfmt"],
        "profiles": ["fix"],
        "tags": ["nix", "format", "fix"],
        "sandbox_safe": false,
        "mutates": true,
        "when": {
          "changed": {
            "paths": ["modules/**/*.nix"]
          }
        }
      },
      {
        "id": "statix-fix",
        "description": "Auto-fix statix warnings where safe",
        "phase": "fix",
        "kind": "command",
        "command": ["statix", "fix"],
        "profiles": ["fix"],
        "tags": ["nix", "lint", "fix"],
        "sandbox_safe": false,
        "mutates": true,
        "when": {
          "changed": {
            "paths": ["modules/**/*.nix"]
          }
        }
      }
    ]
  }
}
