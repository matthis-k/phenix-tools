{
  "version": 1,
  "node": {
    "id": "phenix-tools",
    "description": "Verify the phenix-tools workspace",
    "tags": ["tooling", "foundation"],
    "when": {
      "changed": {
        "paths": ["Cargo.toml", "Cargo.lock", "crates/**/*.rs", "modules/**/*.nix", ".tend.json"]
      }
    },
    "tasks": [
      {
        "id": "tend-crate-files",
        "phase": "verify",
        "kind": "filesExist",
        "profiles": ["git-hook", "pre-push", "manual", "nix-check"],
        "tags": ["tend", "fast"],
        "sandbox_safe": true,
        "paths": [
          "crates/tend/Cargo.toml",
          "crates/tend/src/lib.rs",
          "crates/tend-cli/Cargo.toml",
          "crates/tend-cli/src/main.rs"
        ],
        "when": {
          "changed": {
            "paths": ["crates/**"]
          }
        }
      },
      {
        "id": "rustfmt-check",
        "description": "Check Rust formatting",
        "phase": "verify",
        "kind": "command",
        "command": ["cargo", "fmt", "--all", "--check"],
        "profiles": ["git-hook", "pre-push", "manual", "nix-check"],
        "tags": ["format", "rust"],
        "sandbox_safe": true,
        "mutates": false,
        "always": true,
        "when": {
          "changed": {
            "paths": ["Cargo.toml", "Cargo.lock", "crates/**/*.rs", "modules/**/*.nix"]
          }
        }
      },
      {
        "id": "cargo-check",
        "description": "Check that the workspace compiles cleanly",
        "phase": "verify",
        "kind": "command",
        "command": ["cargo", "check", "--quiet", "--workspace", "--all-targets"],
        "profiles": ["pre-push", "manual", "nix-check"],
        "tags": ["rust", "compile"],
        "sandbox_safe": true,
        "mutates": false,
        "always": true,
        "when": {
          "changed": {
            "paths": ["Cargo.toml", "Cargo.lock", "crates/**/*.rs"]
          }
        }
      },
      {
        "id": "cargo-clippy",
        "description": "Run clippy with deny-warnings on workspace",
        "phase": "verify",
        "kind": "command",
        "command": ["cargo", "clippy", "--quiet", "--workspace", "--all-targets", "--", "-D", "warnings"],
        "profiles": ["pre-push", "manual", "nix-check"],
        "tags": ["rust", "lint"],
        "sandbox_safe": true,
        "mutates": false,
        "always": true,
        "when": {
          "changed": {
            "paths": ["Cargo.toml", "Cargo.lock", "crates/**/*.rs"]
          }
        }
      },
      {
        "id": "cargo-test",
        "description": "Run Rust tests",
        "phase": "verify",
        "kind": "command",
        "command": ["cargo", "test", "--workspace"],
        "profiles": ["manual", "nix-check"],
        "tags": ["rust", "test"],
        "sandbox_safe": true,
        "mutates": false,
        "always": true,
        "when": {
          "changed": {
            "paths": ["Cargo.toml", "Cargo.lock", "crates/**/*.rs"]
          }
        }
      },
      {
        "id": "rustfmt-fix",
        "description": "Fix Rust formatting",
        "phase": "fix",
        "kind": "command",
        "command": ["cargo", "fmt", "--all"],
        "profiles": ["fix"],
        "tags": ["format", "rust", "fix"],
        "sandbox_safe": false,
        "mutates": true,
        "when": {
          "changed": {
            "paths": ["Cargo.toml", "Cargo.lock", "crates/**/*.rs"]
          }
        }
      }
    ]
  }
}
