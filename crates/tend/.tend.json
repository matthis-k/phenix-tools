{
  "version": 1,
  "node": {
    "id": "tend-dev",
    "description": "Verify the tend crate itself",
    "tags": ["tooling", "rust", "foundation"],
    "when": {
      "changed": {
        "paths": ["**/*.rs", "Cargo.toml", ".tend.json"]
      }
    },
    "tasks": [
      {
        "id": "crate-files-exist",
        "phase": "verify",
        "kind": "filesExist",
        "profiles": ["git-hook", "pre-push", "manual", "nix-check"],
        "tags": ["tend", "fast"],
        "sandbox_safe": true,
        "paths": [
          "Cargo.toml",
          "src/lib.rs"
        ]
      }
    ]
  }
}
